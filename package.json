{
  "name": "@geekvetica/source",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Geekvetica Paweł Wojciechowski",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "build": "nx build nx-astro",
    "test": "nx test nx-astro",
    "test:e2e": "nx e2e nx-astro-e2e",
    "test:all": "nx run-many -t test && nx e2e nx-astro-e2e",
    "lint": "nx run-many -t lint --all",
    "lint:fix": "nx run-many -t lint --all --fix",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "typecheck": "nx run-many -t build --all",
    "clean": "nx reset && rm -rf dist node_modules/.cache",
    "release": "nx release",
    "verify": "npm run format:check && npm run lint && npm run test && npm run build",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@astrojs/node": "^10.0.6",
    "@nx/devkit": "22.7.1",
    "astro": "^6.1.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.7.1",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/jest": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/plugin": "22.7.1",
    "@nx/workspace": "22.7.1",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.33",
    "@swc/helpers": "0.5.21",
    "@types/jest": "^30.0.0",
    "@types/node": "25.6.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "jest-util": "^30.3.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^16.4.0",
    "memfs": "^4.57.2",
    "nx": "22.7.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-node": "10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1",
    "verdaccio": "6.5.2"
  },
  "nx": {
    "includedScripts": []
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "provenance": "true"
  }
}
